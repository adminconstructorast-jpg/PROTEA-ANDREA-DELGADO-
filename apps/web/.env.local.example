# Configuración pública del cliente Firebase (NO es secreta).
# Cópialo a apps/web/.env.local y llénalo con los valores de la consola de Firebase.
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=protea-andrea-delgado.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=protea-andrea-delgado
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=protea-andrea-delgado.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# App Check (reCAPTCHA v3) — clave PÚBLICA del sitio.
# Consola de Firebase → App Check → registra la app web con reCAPTCHA v3.
# Con esto el cliente emite tokens; el backend los exige cuando
# APP_CHECK_ENFORCE=true (GitHub Secret). Déjalo vacío para no activar aún.
NEXT_PUBLIC_FIREBASE_APPCHECK_KEY=
